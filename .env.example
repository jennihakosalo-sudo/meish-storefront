# Meish Printed — checkout environment (MEI-4).
# Copy to `.env` and fill in. NEVER commit real keys. Use TEST keys until launch.

# Stripe secret key. Test keys start with `sk_test_...`.
# Ask the CEO for the studio's Stripe test credentials.
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe webhook signing secret for /api/stripe-webhook. Starts with `whsec_...`.
# Local dev: run `stripe listen --forward-to localhost:4321/api/stripe-webhook`
# and copy the `whsec_...` it prints. Production: from the Stripe dashboard
# webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Absolute base URL used to build Stripe success/cancel redirect URLs.
# Optional in dev (falls back to the request origin, e.g. http://localhost:4321).
# Set in production, e.g. https://meish.work
PUBLIC_SITE_URL=

# Where captured orders are stored (MVP file store). Defaults to `.data/orders`.
# Swap the store implementation in src/lib/orders.ts for a hosted DB in prod.
ORDERS_DIR=.data/orders

# --- Reserve-interest flow (MEI-20) --------------------------------------
# The reserve flow runs fully WITHOUT any of these: reservations are stored to
# disk and both emails are written to .data/outbox (OUTBOX mode). Set the key
# below to switch OUTBOX → real delivery for the live site.

# Transactional email via Resend. Get a key at https://resend.com (free tier).
# When set, the studio-notify and customer-confirmation emails are sent for
# real; when unset, they're captured in .data/outbox instead.
RESEND_API_KEY=

# Where reservations are stored (MVP file store). Defaults to `.data/reservations`.
# Swap the store in src/lib/reservations.ts for Airtable/Sheets/DB in prod.
RESERVATIONS_DIR=.data/reservations

# Studio inbox(es) that get the "new reservation" email. Defaults to
# moona.m@meish.work. MAY be a comma-separated list so the notification also
# reaches a live-monitored inbox DIRECTLY via Resend — do NOT rely on a mailbox
# auto-forward for monitoring (Gmail does not forward Spam-classified mail, so a
# forward-based monitor misses the spam/scam wave). See docs/EMAIL-DELIVERABILITY.md.
# Go-live example (studio + anti-abuse monitor):
#   RESERVE_NOTIFY_EMAIL=moona.m@meish.work,jenni.hakosalo@gmail.com
RESERVE_NOTIFY_EMAIL=moona.m@meish.work
# From address for outgoing reserve emails. Must be a domain verified in Resend.
RESERVE_FROM_EMAIL=Meish Printed <hello@meish.work>
# Local outbox dir used when RESEND_API_KEY is unset. Defaults to `.data/outbox`.
OUTBOX_DIR=.data/outbox
# --- CAPTCHA / Cloudflare Turnstile (MEI-26) -----------------------------
# Anti-spam challenge for the reserve form. All THREE settings below go
# together at go-live; leaving them unset keeps the form keyless (dev/OUTBOX).
#
# Set to 1 to require a valid Turnstile token before a reservation is accepted.
# When on, the server verifies the token before storing/emailing and FAILS
# CLOSED (rejects) if the secret is missing — never silently waves traffic through.
RESERVE_REQUIRE_CAPTCHA=
# Turnstile SECRET key (server-side siteverify). Get a widget at
# https://dash.cloudflare.com → Turnstile (free). Keep secret — never commit.
TURNSTILE_SECRET_KEY=
# Turnstile SITE key (public — safe to ship in HTML). Must be PUBLIC_-prefixed
# so Astro exposes it to the rendered form. When set, the widget renders.
PUBLIC_TURNSTILE_SITE_KEY=
