---
const year = 2026; // build-time constant; storefront is static
---

<footer class="site-footer">
  <div class="container container--wide grid">
    <div>
      <p class="wordmark">Meish</p>
      <p class="blurb">An ecosystem for the human experience — a venture portfolio,
        Experience Ops for spaces and events, and the tools and philosophy behind them.</p>
    </div>
    <nav aria-label="Meish">
      <p class="col-title">Meish</p>
      <ul>
        <li><a href="/about">About Meish</a></li>
        <li><a href="/for-business">For your business</a></li>
        <li><a href="/services">For your space</a></li>
        <li><a href="/philosophy">Philosophy</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
    <nav aria-label="Meish Printed">
      <p class="col-title">Meish Printed · shop</p>
      <ul>
        <li><a href="/for-business/meish-treasure/meish-printed">About Meish Printed</a></li>
        <li><a href="/shop">All products</a></li>
        <li><a href="/reserve">Reserve a print</a></li>
      </ul>
    </nav>
  </div>
  <div class="container container--wide baseline">
    <p>© {year} Meish. All rights reserved.</p>
    <p>Made on <a href="https://meish.work">meish.work</a></p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-4xl);
    background: var(--bg-alt);
    border-top: var(--border-hair);
    padding-block: var(--space-2xl) var(--space-xl);
  }
  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: var(--text-lg);
    color: var(--text);
    margin-bottom: var(--space-sm);
  }
  .wordmark span { color: var(--accent); font-style: italic; font-weight: 400; margin-left: 0.28em; }
  .blurb { color: var(--text-muted); font-size: var(--text-sm); max-width: 42ch; }
  .col-title {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }
  nav ul { list-style: none; padding: 0; display: grid; gap: var(--space-xs); }
  nav a { color: var(--text-soft); font-size: var(--text-sm); }
  nav a:hover { color: var(--accent); }
  .baseline {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    padding-top: var(--space-lg);
    border-top: var(--border-hair);
    color: var(--text-muted);
    font-size: var(--text-xs);
  }
  .baseline a { color: var(--text-muted); }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; gap: var(--space-lg); }
    .baseline { flex-direction: column; }
  }
</style>
