---
const links = [
  { href: '/services', label: 'Services' },
  { href: '/philosophy', label: 'Philosophy' },
  { href: '/shop', label: 'Shop' },
  { href: '/about', label: 'Studio' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="container container--wide bar">
    <a href="/" class="wordmark" aria-label="Meish Printed — home">
      Meish<span class="wordmark__mark">Printed</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="nav__link"
              aria-current={path === l.href ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a
      href="/cart"
      class="cart-link"
      aria-current={path === '/cart' ? 'page' : undefined}
      aria-label="Cart"
    >
      Cart<span class="cart-badge" data-cart-count hidden>0</span>
    </a>
    <a href="/shop" class="button button--primary header-cta">Shop the studio</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: var(--border-hair);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    min-height: 4.5rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-tight);
    color: var(--text);
    margin-right: auto;
  }
  .wordmark:hover { color: var(--text); text-decoration: none; }
  .wordmark__mark {
    color: var(--accent);
    font-weight: var(--weight-regular);
    font-style: italic;
    margin-left: 0.28em;
  }
  .nav {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
    padding: 0;
  }
  .nav__link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-soft);
    letter-spacing: 0.01em;
  }
  .nav__link:hover,
  .nav__link[aria-current='page'] {
    color: var(--text);
    text-decoration: none;
  }
  .nav__link[aria-current='page'] { border-bottom: 2px solid var(--accent); }

  .cart-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-soft);
    letter-spacing: 0.01em;
  }
  .cart-link:hover,
  .cart-link[aria-current='page'] { color: var(--text); text-decoration: none; }
  .cart-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.35rem;
    height: 1.35rem;
    padding: 0 0.4rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--color-paper-raised);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    line-height: 1;
  }

  @media (max-width: 640px) {
    .header-cta { display: none; }
    .bar { gap: var(--space-md); min-height: 3.75rem; }
    .nav { gap: var(--space-md); }
  }
</style>
