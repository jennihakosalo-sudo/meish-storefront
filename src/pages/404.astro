---
import Base from '../layouts/Base.astro';
---
<Base title="Not found — Meish Printed">
  <section class="section container" style="text-align:center; padding-block: var(--space-4xl);">
    <p class="eyebrow">Error 404</p>
    <h1 style="font-size: var(--text-3xl); font-weight: 900;">This page went to print<br/>and never came back.</h1>
    <p class="lead" style="margin-inline:auto;">Let's get you somewhere with ink on it.</p>
    <p style="margin-top: var(--space-lg);"><a class="button button--primary" href="/">Back home</a></p>
  </section>
</Base>
