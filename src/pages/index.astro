---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import { categories, productsByCategory } from '../data/products';

// One product to represent the Meish Printed venture on the parent homepage —
// the shop is shown as ONE venture inside Meish, not as the site's identity.
const featured = categories
  .map((cat) => productsByCategory(cat.id)[0])
  .filter((p) => p !== undefined)
  .slice(0, 3);

const areas = [
  { href: '/for-business', label: 'Meish for your business', blurb: 'Our venture portfolio — businesses we build and run, starting with Meish Treasure.' },
  { href: '/services', label: 'Meish for your space', blurb: 'Experience Audits and Clara — measure and improve the human experience in hotels, events and journeys.' },
  { href: '/for-you', label: 'Meish for you', blurb: 'Support for individuals — growth, decision support, everyday guidance.' },
  { href: '/tools', label: 'Meish tools', blurb: 'The methods behind the work — the Abundance Tool, Design Thinking gate and more.' },
  { href: '/philosophy', label: 'Philosophy', blurb: 'Why we measure what others don’t dare to measure.' },
  { href: '/contact', label: 'Contact', blurb: 'Start one conversation.' },
];
---

<Base
  title="Meish — making the human experience lighter, clearer and more enjoyable"
  description="Meish is an ecosystem for the human experience: a venture portfolio, Experience Ops for spaces and events, tools and methods. Making the human experience lighter, clearer and more enjoyable — with love."
>
  <!-- Hero ---------------------------------------------------------------- -->
  <section class="hero section">
    <div class="container hero__inner">
      <p class="eyebrow">Meish</p>
      <h1 class="hero__title">
        Making the human experience<br /><em>lighter, clearer, and more enjoyable.</em>
      </h1>
      <p class="lead hero__lead">
        Meish is an ecosystem, not a single product: a portfolio of businesses,
        Experience Ops for spaces and events, and the tools and philosophy behind
        them. One umbrella — many ways in.
      </p>
      <div class="hero__actions">
        <a href="/for-business" class="button button--primary">Explore the ecosystem</a>
        <a href="/contact" class="button button--ghost">Get in touch</a>
      </div>
    </div>
  </section>

  <hr class="rule container" />

  <!-- The six areas ------------------------------------------------------- -->
  <section class="section">
    <div class="container--wide container">
      <div class="section-head">
        <p class="eyebrow">Ways in</p>
        <h2>Six doors into Meish</h2>
      </div>
      <ul class="areas">
        {areas.map((a) => (
          <li class="area">
            <a href={a.href}><h3>{a.label}</h3></a>
            <p>{a.blurb}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Venture spotlight: Meish Printed ------------------------------------ -->
  <section class="section band">
    <div class="container band__inner">
      <p class="eyebrow">From the portfolio · Meish for your business</p>
      <h2 class="band__title">Meish Treasure → Meish Printed</h2>
      <p class="lead">
        <strong>Meish Printed</strong> is one operating venture inside
        <a href="/for-business/meish-treasure">Meish Treasure</a>, our venture
        foundry — a boutique print studio for custom quotes, wall décor, tin
        plates and restaurant pieces. It’s one business among several in the Meish
        ecosystem, with its own shop and story.
      </p>
      <ul class="grid">
        {featured.map((p) => <ProductCard product={p} />)}
      </ul>
      <p class="section-more">
        <a href="/for-business/meish-treasure/meish-printed" class="link-more">Meet Meish Printed →</a>
        &nbsp;·&nbsp;
        <a href="/shop" class="link-more">Visit the shop →</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .hero { padding-top: var(--space-2xl); }
  .hero__inner { max-width: 52rem; }
  .hero__title {
    font-size: var(--text-hero);
    font-weight: var(--weight-black);
    line-height: 0.98;
    margin-block: var(--space-md) var(--space-lg);
  }
  .hero__title em { color: var(--accent); font-style: italic; font-weight: 400; }
  .hero__lead { margin-bottom: var(--space-xl); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-md); }

  .section-head { margin-bottom: var(--space-xl); }
  .section-head h2 { margin-top: var(--space-xs); }

  .areas {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17rem), 1fr));
    gap: var(--space-xl);
  }
  .area h3 { margin: 0 0 var(--space-2xs); }
  .area p { color: var(--text-soft); }

  .grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }
  .section-more { margin-top: var(--space-xl); }
  .link-more {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
  }

  .band { background: var(--bg-alt); border-block: var(--border-hair); }
  .band__inner { max-width: 52rem; }
  .band__title { margin-block: var(--space-xs) var(--space-md); font-size: var(--text-2xl); }
</style>
