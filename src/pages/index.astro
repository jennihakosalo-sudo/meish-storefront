---
import Base from '../layouts/Base.astro';

// Placeholder featured products. MEI-18 replaces this with the real content
// model (git-based / headless CMS) a non-technical admin can edit.
const featured = [
  { name: 'Kitchen Wisdom', category: 'Wall décor', price: 'from €24', tone: '#c98a5e' },
  { name: 'The Regulars', category: 'Tin plates', price: 'from €18', tone: '#7d8b74' },
  { name: 'Table No. 6', category: 'Restaurant single-use', price: 'from €0.40', tone: '#b4552d' },
];
---

<Base>
  <!-- Hero ---------------------------------------------------------------- -->
  <section class="hero section">
    <div class="container hero__inner">
      <p class="eyebrow">A boutique print studio</p>
      <h1 class="hero__title">
        Words worth<br /><em>framing.</em>
      </h1>
      <p class="lead hero__lead">
        Custom quotes, wall décor, tin plates and single-use pieces for
        restaurants — printed to order in small, considered runs. Bring your own
        design, or start from one of ours.
      </p>
      <div class="hero__actions">
        <a href="/shop" class="button button--primary">Browse the shop</a>
        <a href="/reserve" class="button button--ghost">Reserve a print</a>
      </div>
    </div>
  </section>

  <hr class="rule container" />

  <!-- Featured ------------------------------------------------------------ -->
  <section class="section">
    <div class="container--wide container">
      <div class="section-head">
        <p class="eyebrow">Featured this season</p>
        <h2>Made to be looked at twice</h2>
      </div>
      <ul class="grid">
        {featured.map((p) => (
          <li class="card">
            <a href="/shop" class="card__link">
              <div class="card__thumb" style={`--tone:${p.tone}`}>
                <span class="card__placeholder">Photography — {p.name}</span>
              </div>
              <div class="card__body">
                <span class="tag">{p.category}</span>
                <h3 class="card__name">{p.name}</h3>
                <p class="card__price">{p.price}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Value / brand ------------------------------------------------------- -->
  <section class="section band">
    <div class="container band__inner">
      <p class="eyebrow">Why Meish</p>
      <h2 class="band__title">Small runs. Real paper. No filler.</h2>
      <p class="lead">
        Everything is made to order, so nothing is wasted and every piece is
        yours. Send us a quote that made you laugh, a recipe worth keeping, or a
        menu that needs a hundred beautiful copies — we print it with care.
      </p>
      <a href="/reserve" class="button button--primary">Reserve yours</a>
    </div>
  </section>
</Base>

<style>
  .hero { padding-top: var(--space-2xl); }
  .hero__inner { max-width: 52rem; }
  .hero__title {
    font-size: var(--text-hero);
    font-weight: var(--weight-black);
    line-height: 0.98;
    margin-block: var(--space-md) var(--space-lg);
  }
  .hero__title em { color: var(--accent); font-style: italic; font-weight: 400; }
  .hero__lead { margin-bottom: var(--space-xl); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-md); }

  .section-head { margin-bottom: var(--space-xl); }
  .section-head h2 { margin-top: var(--space-xs); }

  .grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: var(--space-xl);
  }
  .card__link { display: block; color: var(--text); }
  .card__link:hover { color: var(--text); text-decoration: none; }
  .card__thumb {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-md);
    background: linear-gradient(160deg,
      color-mix(in srgb, var(--tone) 22%, var(--surface)),
      color-mix(in srgb, var(--tone) 44%, var(--bg-alt)));
    border: var(--border-hair);
    display: grid;
    place-items: center;
    overflow: hidden;
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .card__link:hover .card__thumb {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .card__placeholder {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 45%, transparent);
  }
  .card__body { padding-top: var(--space-md); }
  .card__name { font-size: var(--text-lg); margin-top: var(--space-2xs); }
  .card__price { color: var(--text-muted); font-size: var(--text-sm); margin-top: var(--space-2xs); }

  .band { background: var(--bg-alt); border-block: var(--border-hair); }
  .band__inner { max-width: 44rem; }
  .band__title { margin-block: var(--space-xs) var(--space-md); font-size: var(--text-2xl); }
  .band .button { margin-top: var(--space-lg); }
</style>
