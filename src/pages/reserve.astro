---
import Base from '../layouts/Base.astro';
import ReserveForm from '../components/ReserveForm.astro';
---
<Base
  title="Reserve a print — Meish Printed"
  description="Tell us what you'd like printed. No card needed — we hold your interest and reply by email."
>
  <section class="section container">
    <p class="eyebrow">Reserve interest</p>
    <h1>Tell us what to print</h1>
    <p class="lead">No card needed yet. Leave your name, email and what you have
      in mind — we'll record your interest, send you a confirmation, and reply by
      email to talk details and a quote.</p>
    <ReserveForm source="reserve-page" />
  </section>
</Base>
