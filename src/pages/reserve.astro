---
import Base from '../layouts/Base.astro';
// Skeleton. The working reserve-interest flow (form → store + email to
// moona.m@meish.work + customer confirmation, with anti-spam) is MEI-21.
---
<Base title="Reserve a print — Meish Printed">
  <section class="section container">
    <p class="eyebrow">Reserve interest</p>
    <h1>Tell us what to print</h1>
    <p class="lead">The reservation form — name, email, product, quantity and a
      note — plugs in here. No card needed yet: it records your interest and we
      reply by email. Anti-spam is built into the final version.</p>
    <p><a class="button button--ghost" href="/shop">Back to the shop</a></p>
  </section>
</Base>
