---
import Base from '../../layouts/Base.astro';
import ReserveForm from '../../components/ReserveForm.astro';
import { products, categoryName, aspectRatio } from '../../data/products';
import { getPricedProduct, formatPrice } from '../../lib/pricing';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const cat = categoryName(product.category);
const ratio = aspectRatio(product);
// Machine price for the checkout path (MEI-4). Every catalogue item is priced,
// but guard so an unpriced future product still renders the design CTA.
const priced = getPricedProduct(product.slug);
---

<Base
  title={`${product.name} — Meish Printed`}
  description={product.description}
>
  <article class="section container container--wide detail">
    <p class="crumbs">
      <a href="/shop">Shop</a>
      <span aria-hidden="true">/</span>
      <a href={`/shop#${product.category}`}>{cat}</a>
    </p>

    <div class="detail__grid">
      <div class="detail__preview">
        <div
          class="preview"
          style={`--tone:${product.tone}; aspect-ratio:${ratio};`}
        >
          {product.image && (
            <img class="preview__img" src={product.image} alt={product.name} />
          )}
          <div class="preview__stage">
            {!product.image && <span class="preview__name">{product.name}</span>}
            <span class="preview__hint">Design preview appears in the studio</span>
          </div>
          <span class="preview__ratio">{product.orientationNote}</span>
        </div>
      </div>

      <div class="detail__info">
        <span class="tag">{cat}</span>
        <h1>{product.name}</h1>
        <p class="detail__tagline">{product.tagline}</p>
        <p class="detail__price">{product.priceLabel}</p>
        <p class="detail__desc">{product.description}</p>

        <a class="button button--primary detail__cta" href={`/design/${product.slug}`}>
          Design it in the browser →
        </a>

        {priced && (
          <form
            class="detail__buy"
            data-add-to-cart
            data-product-id={product.slug}
            data-customizable="true"
          >
            <p class="detail__buy-lead">
              Already know what you want? Add it straight to your cart —
              <strong>{formatPrice(priced.price.unitAmountCents, priced.price.currency)}</strong>
              {' '}{priced.price.unitLabel}{priced.price.minQuantity > 1 ? `, min ${priced.price.minQuantity}` : ''}.
            </p>
            <label class="field">
              <span class="field__label">What should we print? (your words, or a link to your saved design)</span>
              <textarea name="artifact" rows="2" required
                placeholder="e.g. “and still, we rise” — or a link to your exported proof"></textarea>
            </label>
            <div class="detail__buy-actions">
              <label class="qty-field">
                <span class="visually-hidden">Quantity</span>
                <input type="number" name="quantity"
                  value={priced.price.minQuantity} min={priced.price.minQuantity} max="999" inputmode="numeric" />
              </label>
              <button type="submit" class="button button--ghost">Add to cart</button>
            </div>
          </form>
        )}

        <dl class="specs">
          <div>
            <dt>Material</dt>
            <dd>{product.material}</dd>
          </div>
          <div>
            <dt>Print size</dt>
            <dd>{product.width_mm} × {product.height_mm} mm</dd>
          </div>
          <div>
            <dt>Resolution</dt>
            <dd>{product.dpi} dpi (print-ready)</dd>
          </div>
          <div>
            <dt>Starts from</dt>
            <dd>{product.templates.length} template{product.templates.length > 1 ? 's' : ''}</dd>
          </div>
        </dl>

        <p class="detail__note">
          The studio lets you set your own text, upload a photo and preview the
          exact print. When you’re happy, export a print-ready proof and we take
          it from there.
        </p>
      </div>
    </div>

    <section class="reserve-block" id="reserve">
      <div class="reserve-block__intro">
        <p class="eyebrow">No card needed</p>
        <h2>Reserve this print</h2>
        <p class="reserve-block__lead">
          Not ready to check out? Tell us you're interested in
          <strong>{product.name}</strong> and we'll email you back to talk
          details and a quote. We only record your interest — nothing is charged.
        </p>
      </div>
      <ReserveForm
        product={{ slug: product.slug, name: product.name }}
        source={`product:${product.slug}`}
      />
    </section>
  </article>
</Base>

<style>
  .crumbs {
    font-size: var(--text-sm);
    color: var(--text-muted);
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
  }
  .reserve-block {
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: var(--border-hair);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: var(--space-3xl);
    align-items: start;
  }
  .reserve-block__intro h2 { margin-top: var(--space-2xs); }
  .reserve-block__lead {
    margin-top: var(--space-md);
    color: var(--text-soft);
  }
  @media (max-width: 820px) {
    .reserve-block { grid-template-columns: 1fr; gap: var(--space-xl); }
  }
  .detail__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: var(--space-3xl);
    align-items: start;
  }
  .preview {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: var(--border-hair);
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--tone) 22%, var(--surface)),
      color-mix(in srgb, var(--tone) 48%, var(--color-paper-sunk))
    );
    box-shadow: var(--shadow-md);
    max-height: 72vh;
  }
  .preview__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .preview__stage {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    text-align: center;
    padding: var(--space-xl);
  }
  .preview__name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-2xl);
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
  }
  .preview__hint {
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }
  .preview__ratio {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
    background: color-mix(in srgb, var(--color-paper-raised) 70%, transparent);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-pill);
  }
  .detail__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-md);
    color: var(--text-soft);
    margin-top: 0.3em;
  }
  .detail__price {
    margin-top: var(--space-sm);
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    color: var(--accent);
  }
  .detail__desc {
    margin-top: var(--space-lg);
    color: var(--text-soft);
  }
  .detail__cta {
    margin-top: var(--space-xl);
  }
  .specs {
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    border-top: var(--border-hair);
    padding-top: var(--space-lg);
  }
  .specs dt {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .specs dd {
    margin-top: 0.2em;
    font-size: var(--text-sm);
    color: var(--text);
  }
  .detail__note {
    margin-top: var(--space-xl);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .detail__buy {
    margin-top: var(--space-lg);
    padding: var(--space-lg);
    border: var(--border-hair);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .detail__buy-lead { margin: 0 0 var(--space-md); font-size: var(--text-sm); color: var(--text-soft); }
  .field { display: block; margin-bottom: var(--space-md); }
  .field__label {
    display: block;
    font-size: var(--text-sm);
    color: var(--text-soft);
    margin-bottom: var(--space-2xs);
  }
  .detail__buy textarea,
  .qty-field input {
    width: 100%;
    font: inherit;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xs) var(--space-sm);
  }
  .detail__buy textarea { resize: vertical; }
  .detail__buy textarea:focus,
  .qty-field input:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .detail__buy-actions { display: flex; gap: var(--space-sm); align-items: center; }
  .qty-field { width: 5.5rem; flex: none; }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  @media (max-width: 820px) {
    .detail__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .preview {
      max-width: 26rem;
    }
  }
</style>
